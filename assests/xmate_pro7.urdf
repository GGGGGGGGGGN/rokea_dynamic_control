<?xml version="1.0" ?>
<robot name="xMatePro7">
  <mujoco>
    <compiler strippath="false"/>
  </mujoco>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  
  <link name="world"/>
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="xMatePro7_base"/>
    <origin xyz="0 0 0" rpy="0 0.3490659 0"/> 
    <!-- <origin xyz="0 0 0" rpy="0 0 0"/> -->
    <!-- 这里为了和安装的姿态对应，添加了倾斜角度，为20度，但实际上也不知道安装了多少度，大概就是这个水平吧先 -->
  </joint>
  
  <link name="xMatePro7_base">
    <visual>
      <geometry>
        <mesh filename="xMateER7p/visual/xMatePro7_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <collision>
